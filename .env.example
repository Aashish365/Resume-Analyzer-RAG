# Copy to .env and adjust values for your environment.
# For Docker Compose, service hostnames (chromadb, redis, postgres, ollama)
# are automatically overridden in docker-compose.yml — keep localhost values
# here for direct local dev.

# LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings
# "harrier" uses microsoft/harrier-oss-v1-0.6b via sentence-transformers (recommended)
# "ollama" falls back to nomic-embed-text via Ollama
EMBEDDING_PROVIDER=harrier
HARRIER_MODEL=microsoft/harrier-oss-v1-0.6b

# Vector DB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Async
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Database
POSTGRES_USER=resumeanalyzer
POSTGRES_PASSWORD=changeme
POSTGRES_DB=resumeanalyzer
DATABASE_URL=postgresql+asyncpg://resumeanalyzer:changeme@localhost:5432/resumeanalyzer

# File storage
UPLOAD_DIR=./backend/uploads
MAX_FILE_SIZE_MB=10
MAX_JD_CHARS=20000
