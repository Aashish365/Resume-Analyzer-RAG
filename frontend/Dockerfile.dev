FROM node:20-alpine
WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json* ./
RUN npm install

# Copy full source into the image as a fallback.
# The docker-compose volume mount (./frontend/src:/app/src) overlays this
# at runtime so live edits are still reflected without rebuilding.
COPY . .

EXPOSE 3000
CMD ["npm", "run", "dev"]
